										ElementName=CowboyHatAbilityBorder}"
									ActiveImageSource="{StaticResource ActiveCowboyHatImage}"
									InactiveImageSource
										="{StaticResource InactiveCowboyHatImage}"
									LabelContent="Cowboy Hat"
									Style="{StaticResource FarmSideToggleStyle}" />

						</StackPanel>

						<Border
								x:Name="HolsteinFriesianAbilityBorder"
								Grid.Column="1"
								Visibility="Visible"
								Style="{StaticResource AbilityBorderStyle}">

							<StackPanel Style="{StaticResource StepStackPanelStyle}">

								<TextBlock Style="{StaticResource StepTitleTextBlockStyle}">
									Holstein Friesians
								</TextBlock>

								<TextBox
										Style="{StaticResource StepDescriptionTextBoxStyle}" >
									Holstein Friesians are a breed of dairy cattle originating
									from the Dutch provinces. They are known as the world's
									highest-production dairy animals.
								</TextBox>

								<StackPanel Style
										="{StaticResource AbilityValueStackPanelStyle}" >
									<Label Style
											="{StaticResource AbilityValueCaptionLabelStyle}" />
									<Label
											x:Name="HolsteinFriesianBuyingAbilityValue"
											Style="{StaticResource AbilityValueLabelStyle}"
											Content
												="{StaticResource BuyingAbilityNegativeValueText}" />
								</StackPanel>

							</StackPanel>

						</Border>

						<Border
								x:Name="TexasLonghornAbilityBorder"
								Grid.Column="1"
								Visibility="Collapsed"
								Style="{StaticResource AbilityBorderStyle}">

							<StackPanel Style="{StaticResource StepStackPanelStyle}">

								<TextBlock Style="{StaticResource StepTitleTextBlockStyle}">
									Texas Longhorns
								</TextBlock>

								<TextBox
										Style="{StaticResource StepDescriptionTextBoxStyle}" >
									The Texas Longhorn is a breed of cattle
									known for its characteristic horns.
								</TextBox>

								<StackPanel Style
										="{StaticResource AbilityValueStackPanelStyle}" >
									<Label Style
											="{StaticResource AbilityValueCaptionLabelStyle}" />
									<Label
											x:Name="TexasLonghornBuyingAbilityValue"
											Style="{StaticResource AbilityValueLabelStyle}"
											Content
												="{StaticResource BuyingAbilityNegativeValueText}" />
								</StackPanel>

							</StackPanel>

						</Border>

						<Border
								x:Name="FarmerBootsAbilityBorder"
								Grid.Column="1"
								Visibility="Collapsed"
								Style="{StaticResource AbilityBorderStyle}">

							<StackPanel Style="{StaticResource StepStackPanelStyle}">

								<TextBlock Style="{StaticResource StepTitleTextBlockStyle}">
									Farmer Boots
								</TextBlock>

								<StackPanel Style
										="{StaticResource AbilityValueStackPanelStyle}" >
									<Label Style
											="{StaticResource AbilityValueCaptionLabelStyle}" />
									<Label
											x:Name="FarmerBootBuyingAbilityValue"
											Style="{StaticResource AbilityValueLabelStyle}"
											Content
												="{StaticResource BuyingAbilityPositiveValueText}" />
								</StackPanel>

							</StackPanel>

