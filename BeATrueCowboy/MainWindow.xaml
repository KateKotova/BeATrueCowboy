								Style="{StaticResource StepStackPanelStyle}">

							<controls:SideToggleControl
									x:Name="HolsteinFriesianToggle"
									AssociatedUIElement="{Binding
										ElementName=HolsteinFriesianAbilityBorder}"
									ActiveImageSource="{StaticResource ActiveCowImage}"
									InactiveImageSource="{StaticResource InactiveCowImage}"
									LabelContent="Holstein Friesian"
									IsChecked="True"
									Style="{StaticResource FarmSideToggleStyle}" />

							<controls:SideToggleControl
									x:Name="TexasLonghornToggle"
									AssociatedUIElement="{Binding
										ElementName=TexasLonghornAbilityBorder}"
									ActiveImageSource="{StaticResource ActiveLonghornCowImage}"
									InactiveImageSource
										="{StaticResource InactiveLonghornCowImage}"
									LabelContent="Texas Longhorn"
									Style="{StaticResource FarmSideToggleStyle}" />

							<controls:SideToggleControl
									x:Name="FarmerBootsToggle"
									AssociatedUIElement="{Binding
										ElementName=FarmerBootsAbilityBorder}"
									ActiveImageSource="{StaticResource ActiveUrbanBootsImage}"
									InactiveImageSource
										="{StaticResource InactiveUrbanBootsImage}"
									LabelContent="Farmer Boots"
									Style="{StaticResource FarmSideToggleStyle}" />

							<controls:SideToggleControl
									x:Name="RaceHorse"
									AssociatedUIElement="{Binding
										ElementName=RaceHorseAbilityBorder}"
									ActiveImageSource="{StaticResource ActiveRacehorseImage}"
									InactiveImageSource
										="{StaticResource InactiveRacehorseImage}"
									LabelContent="Race Horse"
									Style="{StaticResource FarmSideToggleStyle}" />
							
							<controls:SideToggleControl
									x:Name="CowboyHat"
