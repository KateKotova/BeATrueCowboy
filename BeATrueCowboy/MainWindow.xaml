									GroupIndex="{StaticResource NotAvailableAbilityGroupIndex}"
								Checked="OnDarkIconsForNotAvailableAbilitiesToggleChecked"/>
							<controls:LabledToggleControl
									x:Name="ChangIconsForNotAvailableAbilitiesToggle"
