										="{StaticResource InactiveMrPathfinderImage}"
									LabelContent="Mr. Pathfinder"
									Style="{StaticResource IndianVillageSideToggleStyle}" />

							<controls:SideToggleControl
									x:Name="Trotter"
									AssociatedUIElement="{Binding
										ElementName=TrotterAbilityBorder}"
									ActiveImageSource
