								Visibility="Visible"
								Style="{StaticResource AbilityBorderStyle}">

							<StackPanel Style="{StaticResource StepStackPanelStyle}">

								<TextBlock Style="{StaticResource StepTitleTextBlockStyle}">
									Mr. Argus-Eyed Eagle
								</TextBlock>

								<StackPanel Style
										="{StaticResource AbilityValueStackPanelStyle}" >
									<Label Style
											="{StaticResource AbilityValueCaptionLabelStyle}" />
									<Label
											Style="{StaticResource AbilityValueLabelStyle}"
											Content
												="{StaticResource BorrowingAbilityValueText}" />
								</StackPanel>

							</StackPanel>

						</Border>

						<Border
								x:Name="MrPathfinderAbilityBorder"
								Grid.Column="1"
								Visibility="Collapsed"
								Style="{StaticResource AbilityBorderStyle}">

							<StackPanel Style="{StaticResource StepStackPanelStyle}">

								<TextBlock Style="{StaticResource StepTitleTextBlockStyle}">
									Mr. Pathfinder
								</TextBlock>

								<StackPanel Style
										="{StaticResource AbilityValueStackPanelStyle}" >
									<Label Style
											="{StaticResource AbilityValueCaptionLabelStyle}" />
									<Label
											Style="{StaticResource AbilityValueLabelStyle}"
											Content
												="{StaticResource BorrowingAbilityValueText}" />
								</StackPanel>

							</StackPanel>

						</Border>

						<Border
								x:Name="TrotterAbilityBorder"
								Grid.Column="1"
								Visibility="Collapsed"
								Style="{StaticResource AbilityBorderStyle}">

							<StackPanel Style="{StaticResource StepStackPanelStyle}">

								<TextBlock Style="{StaticResource StepTitleTextBlockStyle}">
									Trotters
								</TextBlock>

								<TextBox
										Style="{StaticResource StepDescriptionTextBoxStyle}" >
									If you've ridden horses, you're familiar with the trot,
									or the jog as it's called in Western riding.
									When a horse trots, he moves diagonally paired legs
									simultaneously. That means he's moving his back left
									leg at the same time he's moving his right front leg,
									and his front left leg in unison with the rear right leg.
									A trotting racehorse performs this gait at high speed.
									Some trotters wear trotting hopples, simple front leg loops,
									to aid in keeping the gait.
								</TextBox>

								<StackPanel Style
										="{StaticResource AbilityValueStackPanelStyle}" >
									<Label Style
											="{StaticResource AbilityValueCaptionLabelStyle}" />
									<Label
											x:Name="TrotterBuyingAbilityValue"
											Style="{StaticResource AbilityValueLabelStyle}"
											Content
												="{StaticResource BuyingAbilityNegativeValueText}" />
								</StackPanel>

							</StackPanel>

						</Border>

						<Border
								x:Name="BootsWithSpursAbilityBorder"
								Grid.Column="1"
								Visibility="Collapsed"
								Style="{StaticResource AbilityBorderStyle}">

							<StackPanel Style="{StaticResource StepStackPanelStyle}">

								<TextBlock Style="{StaticResource StepTitleTextBlockStyle}">
									Boots With Spurs
								</TextBlock>

								<StackPanel Style
										="{StaticResource AbilityValueStackPanelStyle}" >
									<Label Style
											="{StaticResource AbilityValueCaptionLabelStyle}" />
									<Label
											x:Name="BootsWithSpursBuyingAbilityValue"
											Style="{StaticResource AbilityValueLabelStyle}"
											Content
												="{StaticResource BuyingAbilityPositiveValueText}" />
								</StackPanel>

							</StackPanel>

						</Border>

					</Grid>

				</Grid>

			</Grid>
		</Border>

		<Border Style="{StaticResource WindowBorderWithOutlineStyle}" />
	</Grid>
</Window>
