<UserControl x:Class="BeATrueCowboy.Controls.LowerBandToggleControl"
		xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
		xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
		xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
		xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
		xmlns:local="clr-namespace:BeATrueCowboy.Controls"
		xmlns:sysWin="clr-namespace:System.Windows;assembly=PresentationFramework"
		xmlns:system="clr-namespace:System;assembly=mscorlib"
		mc:Ignorable="d"
		d:DesignHeight="73"
		d:DesignWidth="71">

	<UserControl.Resources>

		<system:Double x:Key="ImageSide">50</system:Double>

		<Style x:Key="HitAreaImageStyle" TargetType="Image">
			<Setter Property="HorizontalAlignment" Value="Center" />
			<Setter Property="Width" Value="{StaticResource ImageSide}" />
			<Setter Property="Height" Value="{StaticResource ImageSide}" />
			<Setter Property="Margin" Value="0" />
		</Style>

		<FontFamily x:Key="TextFontFamily">
			pack://application:,,,/Resources/#Regulators
		</FontFamily>
		<Style x:Key="HitAreaLabelStyle" TargetType="Label">
			<Setter Property="HorizontalAlignment" Value="Center" />
			<Setter Property="Padding" Value="0" />
			<Setter Property="FontFamily" Value="{StaticResource TextFontFamily}" />
		</Style>
		<Style x:Key="HitAreaNormalLabelStyle"
				TargetType="Label"
				BasedOn="{StaticResource HitAreaLabelStyle}">
			<Setter Property="FontSize" Value="13" />
			<Setter Property="Margin" Value="0,1,0,0" />
		</Style>
		<Style x:Key="HitAreaTightLabelStyle"
				TargetType="Label"
				BasedOn="{StaticResource HitAreaLabelStyle}">
			<Setter Property="FontSize" Value="12" />
			<Setter Property="Margin" Value="0" />
		</Style>

		<system:Double x:Key="WithHitAreaHeight">73</system:Double>

		<system:Double x:Key="HitAreaDoubleHeight">70</system:Double>
		<sysWin:GridLength x:Key="HitAreaGridLengthHeight">70</sysWin:GridLength>

		<system:Double x:Key="ToggleDoubleHeight">3</system:Double>
		<sysWin:GridLength x:Key="ToggleGridLengthHeight">3</sysWin:GridLength>

		<ControlTemplate x:Key="HitAreaTemplate"
				TargetType="local:LabeledImageDataControl">

			<StackPanel
					Width="Auto"
					Height="{StaticResource HitAreaDoubleHeight}"
					HorizontalAlignment="Center"
					Orientation="Vertical"
					Margin="0" >

				<StackPanel
						x:Name="HitArea"
						Width="Auto"
						Height="{StaticResource HitAreaDoubleHeight}"
						HorizontalAlignment="Center"
						Orientation="Vertical"
						Margin="10,0,10,0">
					<Image Style="{TemplateBinding ImageStyle}"
							Source="{TemplateBinding ImageSource}" />
					<Label Style="{TemplateBinding LabelStyle}"
							Content="{TemplateBinding LabelContent}"/>
				</StackPanel>

			</StackPanel>

		</ControlTemplate>

		<Style x:Key="ToggleStyle" TargetType="Canvas">
			<Setter Property="Width" Value="Auto"/>
			<Setter Property="Height" Value="{StaticResource ToggleDoubleHeight}"/>
			<Setter Property="Margin" Value="0"/>
		</Style>

		<SolidColorBrush x:Key="ActiveToggleBackground">#E2182D</SolidColorBrush>

		<BitmapImage x:Key="Test"
				UriSource="/BeATrueCowboy;component/Resources/YouAreCowboy.png" />

	</UserControl.Resources>

	<Grid
			Width="Auto"
			Height="{StaticResource WithHitAreaHeight}"
			Margin="0">

		<Grid.RowDefinitions>
			<RowDefinition Height="{StaticResource HitAreaGridLengthHeight}"/>
			<RowDefinition Height="{StaticResource ToggleGridLengthHeight}"/>
		</Grid.RowDefinitions>

		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="Auto"/>
		</Grid.ColumnDefinitions>

		<local:LabeledImageDataControl
				x:Name="HitArea"
				Grid.Row="0"
				Grid.Column="0"
				ImageStyle="{StaticResource HitAreaImageStyle}"
				ImageSource="{StaticResource Test}"
				LabelContent="Test"
				LabelStyle="{StaticResource HitAreaNormalLabelStyle}"
				Template="{StaticResource HitAreaTemplate}"/>
				<!--
				ImageSource
				LabelStyle -> LabelIsTight
				LabelContent
				-->

		<Canvas
				x:Name="ActiveToggle"
				Grid.Row="1"
				Grid.Column="0"
				Style="{StaticResource ToggleStyle}"
				Background="{StaticResource ActiveToggleBackground}"/>

		<Canvas
				x:Name="InactiveToggle"
				Grid.Row="1"
				Grid.Column="0"
				Style="{StaticResource ToggleStyle}"/>

		<local:SimpleToggleControl
				x:Name="ToggleObject"
				ActiveStateUIElement ="{Binding ElementName=ActiveToggle}"
				InactiveStateUIElement ="{Binding ElementName=InactiveToggle}"
				AdditionalHitAreaUIElement="{Binding ElementName=HitArea}"
				Checked="OnToggleObjectChecked"/>
				<!--
				GroupIndex
				IsChecked
				AssociatedUIElement
				-->

	</Grid>

</UserControl>
