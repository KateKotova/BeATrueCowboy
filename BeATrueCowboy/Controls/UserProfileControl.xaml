<UserControl x:Class="BeATrueCowboy.Controls.UserProfileControl"
		xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
		xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
		xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
		xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
		xmlns:local="clr-namespace:BeATrueCowboy.Controls"
		xmlns:sysWin="clr-namespace:System.Windows;assembly=PresentationFramework"
		xmlns:system="clr-namespace:System;assembly=mscorlib"
		mc:Ignorable="d"
		d:DesignHeight="62"
		d:DesignWidth="480"
		Height="62"
		Width="480" >

	<UserControl.Resources>
		<system:Double x:Key="ControlDoubleHeight">62</system:Double>
		<system:Double x:Key="ControlDoubleWigth">480</system:Double>

		<sysWin:GridLength x:Key="IconAreaGridLengthWidth">63</sysWin:GridLength>
		<system:Double x:Key="IconDoubleSide">45</system:Double>
		<Style x:Key="IconBorderStyle" TargetType="Border">
			<Setter Property="Height" Value="{StaticResource IconDoubleSide}" />
			<Setter Property="Width" Value="{StaticResource IconDoubleSide}" />
			<Setter Property="Margin" Value="9,8,7,7" />
			<Setter Property="Padding" Value="0" />
			<Setter Property="CornerRadius" Value="2,8,3,10" />
			<Setter Property="BorderBrush" Value="#705D42" />
			<Setter Property="BorderThickness" Value="2,1.5,3,5" />
		</Style>

		<sysWin:GridLength x:Key="TextAreaGridLengthWidth">354</sysWin:GridLength>
		<system:Double x:Key="TextAreaDoubleWidth">354</system:Double>

		<sysWin:GridLength x:Key="NameGridLengthHeight">31</sysWin:GridLength>
		<sysWin:GridLength x:Key="NicknameGridLengthHeight">30</sysWin:GridLength>
		<sysWin:GridLength x:Key="CaptionsGridLengthWidth">99</sysWin:GridLength>
		<sysWin:GridLength x:Key="TextValuesGridLengthWidth">255</sysWin:GridLength>

		<FontFamily x:Key="CaptionsFontFamily">
			pack://application:,,,/Resources/#Regulators
		</FontFamily>
		<FontFamily x:Key="TextValuesFontFamily">
			pack://application:,,,/Resources/#Western
		</FontFamily>
		<Brush x:Key="TextValuesForeground">#261F16</Brush>
		<system:Double x:Key="CaptionsFontSize">18</system:Double>
		<system:Double x:Key="TextValuesFontSize">21</system:Double>

		<Style x:Key="LabelStyle" TargetType="Label">
			<Setter Property="HorizontalAlignment" Value="Left" />
			<Setter Property="Padding" Value="0" />
			<Setter Property="Foreground" Value="{StaticResource TextValuesForeground}" />
		</Style>
		<Style x:Key="NameLabelStyle"
				TargetType="Label"
				BasedOn="{StaticResource LabelStyle}">
			<Setter Property="VerticalAlignment" Value="Bottom" />
			<Setter Property="Margin" Value="0" />
		</Style>
		<Style x:Key="NicknameLabelStyle"
				TargetType="Label"
				BasedOn="{StaticResource LabelStyle}">
			<Setter Property="VerticalAlignment" Value="Top" />
			<Setter Property="Margin" Value="0,-2,0,0" />
		</Style>

		<sysWin:GridLength x:Key="MarkersAreaGridLengtheWidth">63</sysWin:GridLength>
		<system:Double x:Key="MarkersAreaDoubleWidth">63</system:Double>
		<system:Double x:Key="MarkerImageDoubleSide">21</system:Double>

		<Style x:Key="MarkerImageStyle" TargetType="Image">
			<Setter Property="Height" Value="{StaticResource MarkerImageDoubleSide}" />
			<Setter Property="Width" Value="{StaticResource MarkerImageDoubleSide}" />
			<Setter Property="Margin" Value="0,18,5,0" />
			<Setter Property="HorizontalAlignment" Value="Left" />
			<Setter Property="VerticalAlignment" Value="Top" />
		</Style>

		<ImageBrush x:Key="BackgroundImage"
				ImageSource="/BeATrueCowboy;component/Resources/UserProfileBar.png" />
		<BitmapImage x:Key="ActiveSelectedProfileImage"
				UriSource="/BeATrueCowboy;component/Resources/Select.png" />
		<BitmapImage x:Key="InactiveSelectedProfileImage"
				UriSource="/BeATrueCowboy;component/Resources/SelectInactive.png" />
		<BitmapImage x:Key="ActiveDeleteProfileImage"
				UriSource="/BeATrueCowboy;component/Resources/Close.png" />
		<BitmapImage x:Key="InactiveDeleteProfileImage"
				UriSource="/BeATrueCowboy;component/Resources/CloseInactive.png" />

		<BitmapImage x:Key="Test"
				UriSource="/BeATrueCowboy;component/Resources/YouAreCowboy.png" />

	</UserControl.Resources>

	<Grid
			Height="{StaticResource ControlDoubleHeight}"
			Width="{StaticResource ControlDoubleWigth}"
			Background="{StaticResource BackgroundImage}">

		<Grid.RowDefinitions>
			<RowDefinition Height="Auto" />
		</Grid.RowDefinitions>

		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="{StaticResource IconAreaGridLengthWidth}"/>
			<ColumnDefinition Width="{StaticResource TextAreaGridLengthWidth}"/>
			<ColumnDefinition Width="{StaticResource MarkersAreaGridLengtheWidth}"/>
		</Grid.ColumnDefinitions>

		<Border
				Grid.Row="0"
				Grid.Column="0"
				Style="{StaticResource IconBorderStyle}">

			<Border.Background>
				<!--ImageBrush x:Name="ImageBrushSource" /-->
				<!--ImageBrush x:Name="ImageBrushSource"
						ImageSource="{Binding IconImageSource}"/-->
				<ImageBrush x:Name="ImageBrushSource"
						ImageSource="{StaticResource Test}"/>
			</Border.Background>
		</Border>

		<Grid
				Grid.Row="0"
				Grid.Column="1"
				Height="{StaticResource ControlDoubleHeight}"
				Width="{StaticResource TextAreaDoubleWidth}"
				Margin="0" >

			<Grid.RowDefinitions>
				<RowDefinition Height="{StaticResource NameGridLengthHeight}" />
				<RowDefinition Height="{StaticResource NicknameGridLengthHeight}" />
			</Grid.RowDefinitions>

			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="{StaticResource CaptionsGridLengthWidth}"/>
				<ColumnDefinition Width="{StaticResource TextValuesGridLengthWidth}"/>
			</Grid.ColumnDefinitions>

			<Label
					Grid.Column="0"
					Grid.Row="0"
					Content="Name:"
					FontFamily="{StaticResource CaptionsFontFamily}"
					FontSize="{StaticResource CaptionsFontSize}"
					Style="{StaticResource NameLabelStyle}" />

			<Label
					Grid.Column="0"
					Grid.Row="1"
					Content="Nickname:"
					FontFamily="{StaticResource CaptionsFontFamily}"
					FontSize="{StaticResource CaptionsFontSize}"
					Style="{StaticResource NicknameLabelStyle}" />

			<Label
					x:Name="NameLabel"
					Grid.Column="1"
					Grid.Row="0"
					Content="PutNameHere"
					FontFamily="{StaticResource TextValuesFontFamily}"
					FontSize="{StaticResource TextValuesFontSize}"
					Style="{StaticResource NameLabelStyle}" />
					<!--Content="Binding NameLabelContent}"-->

			<Label
					x:Name="NicknameLabel"
					Grid.Column="1"
					Grid.Row="1"
					Content="PutNicknameHere"
					FontFamily="{StaticResource TextValuesFontFamily}"
					FontSize="{StaticResource TextValuesFontSize}"
					Style="{StaticResource NicknameLabelStyle}" />
					<!--Content="{Binding NicknameLabelContent}"-->

		</Grid>

		<StackPanel
				Grid.Row="0"
				Grid.Column="2"
				Height="{StaticResource ControlDoubleHeight}"
				Width="{StaticResource MarkersAreaDoubleWidth}"
				Orientation="Horizontal"
				Margin="0" >

			<StackPanel x:Name="SelectProfileToggleContainer">
					<!--Visability={Binding CanSelectProfile}-->

				<Image
						x:Name="ActiveSelectProfileToggle"
						Style="{StaticResource MarkerImageStyle}"
						Source="{StaticResource ActiveSelectedProfileImage}" />

				<Image
						x:Name="InactiveSelectProfileToggle"
						Style="{StaticResource MarkerImageStyle}"
						Source="{StaticResource InactiveSelectedProfileImage}" />

				<local:SimpleToggleControl
						x:Name="SelectProfileToggle"
						IsAvailable="True"
						Checked="OnSelectProfileToggleChecked"
						ActiveStateUIElement
							="{Binding ElementName=ActiveSelectProfileToggle}"
						InactiveStateUIElement
							="{Binding ElementName=InactiveSelectProfileToggle}" />
						<!--
						GroupIndex="{Binding SelectedProfileGroupIndex}"
						IsChecked="{Binding SelectedProfileIsChecked}"
						-->
			</StackPanel>

			<StackPanel x:Name="DeleteProfileToggleContainer">
					<!--Visability={Binding CanDeleteProfile}-->

				<Image
						x:Name="ActiveDeleteProfileToggle"
						Style="{StaticResource MarkerImageStyle}"
						Source="{StaticResource ActiveDeleteProfileImage}" />

				<Image
						x:Name="InactiveDeleteProfileToggle"
						Style="{StaticResource MarkerImageStyle}"
						Source="{StaticResource InactiveDeleteProfileImage}" />

				<local:SimpleToggleControl
						x:Name="DeleteProfileToggle"
						IsAvailable="True"
						Checked="OnDeleteProfileToggleChecked"
						ActiveStateUIElement
							="{Binding ElementName=ActiveDeleteProfileToggle}"
						InactiveStateUIElement
							="{Binding ElementName=InactiveDeleteProfileToggle}" />
			</StackPanel>
		</StackPanel>

	</Grid>
</UserControl>