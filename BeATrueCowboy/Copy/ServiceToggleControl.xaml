<UserControl x:Class="Controls.ServiceSimpleToggle"
		xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
		xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
		xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
		xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
		xmlns:local="clr-namespace:Snack.Settings"
		xmlns:appSettings="clr-namespace:Controls"
		xmlns:sysWin="clr-namespace:System.Windows;assembly=PresentationFramework"
		xmlns:system="clr-namespace:System;assembly=mscorlib"
		mc:Ignorable="d" 
		d:DesignHeight="53" d:DesignWidth="58">
	
	<UserControl.Resources>

		<sysWin:GridLength x:Key="ServiceToggleHeight">53</sysWin:GridLength>
		<sysWin:GridLength x:Key="ServiceToggleWidth">58</sysWin:GridLength>

		<sysWin:GridLength x:Key="ActiveServiceToggleLeftBarWidth">3</sysWin:GridLength>
		<sysWin:GridLength x:Key="ActiveServiceToggleWithoutLeftBarWidth">55</sysWin:GridLength>

		<sysWin:GridLength x:Key="InctiveServiceToggleRightBarWidth">2</sysWin:GridLength>
		<sysWin:GridLength x:Key="InctiveServiceToggleWithoutRightBarWidth">56</sysWin:GridLength>

		<sysWin:GridLength x:Key="InctiveServiceToggleBottomBarHeight">1</sysWin:GridLength>
		<sysWin:GridLength x:Key="InctiveServiceToggleWithoutBottomBarHeight">52</sysWin:GridLength>

		<system:Double x:Key="ImageSide">32</system:Double>
		<system:Double x:Key="LabelFontSize">9</system:Double>
		<system:Double x:Key="TightLabelFontSize">8.5</system:Double>

		<Brush x:Key="InctiveServiceToggleLabelForegroundBrush">#BAC1D1</Brush>

		<Style x:Key="ServiceToggleImageStyle" TargetType="Image">
			<Setter Property="HorizontalAlignment" Value="Center" />
			<Setter Property="Width" Value="{StaticResource ImageSide}" />
			<Setter Property="Height" Value="{StaticResource ImageSide}" />
			<Setter Property="Margin" Value="0,5.5,0,0" />
		</Style>

		<Style x:Key="ServiceToggleImageStyleWhileSecondLabelIsVisible" TargetType="Image">
			<Setter Property="HorizontalAlignment" Value="Center" />
			<Setter Property="Width" Value="{StaticResource ImageSide}" />
			<Setter Property="Height" Value="{StaticResource ImageSide}" />
			<Setter Property="Margin" Value="0,2,0,0" />
		</Style>

		<Style x:Key="ServiceToggleLabelStyle" TargetType="Label">
			<Setter Property="HorizontalAlignment" Value="Center" />
			<Setter Property="FontSize" Value="{StaticResource LabelFontSize}" />
			<Setter Property="Margin" Value="0,-1.5,0,0" />
			<Setter Property="Padding" Value="0" />
		</Style>
		<Style x:Key="ServiceToggleTightLabelStyle" TargetType="Label">
			<Setter Property="HorizontalAlignment" Value="Center" />
			<Setter Property="FontSize" Value="{StaticResource TightLabelFontSize}" />
			<Setter Property="Margin" Value="0,-2,0,0" />
			<Setter Property="Padding" Value="0" />
		</Style>

		<Style x:Key="ServiceToggleSecondLabelStyle" TargetType="Label">
			<Setter Property="HorizontalAlignment" Value="Center" />
			<Setter Property="FontSize" Value="{StaticResource LabelFontSize}" />
			<Setter Property="Margin" Value="0,-4,0,0" />
			<Setter Property="Padding" Value="0" />
		</Style>
		<Style x:Key="ServiceToggleTightSecondLabelStyle" TargetType="Label">
			<Setter Property="HorizontalAlignment" Value="Center" />
			<Setter Property="FontSize" Value="{StaticResource TightLabelFontSize}" />
			<Setter Property="Margin" Value="0,-4,0,0" />
			<Setter Property="Padding" Value="0" />
		</Style>

		<ControlTemplate x:Key="ActiveServiceToggleTemplate"
						TargetType="appSettings:LabeledImageDataControl">
			<Grid
						Width="{Binding ServiceToggleWidth}"
						Height="{Binding ServiceToggleHeight}"
						Margin="0">

				<Grid.RowDefinitions>
					<RowDefinition Height
								="{StaticResource ServiceToggleHeight}" />
				</Grid.RowDefinitions>

				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="{StaticResource ActiveServiceToggleLeftBarWidth}" />
					<ColumnDefinition Width="{StaticResource ActiveServiceToggleWithoutLeftBarWidth}" />
				</Grid.ColumnDefinitions>

				<Canvas Grid.Column="0" Background="#6aa3fb" />

				<StackPanel Grid.Column="1">
					<Image Style="{TemplateBinding ImageStyle}"
						Source="{TemplateBinding ImageSource}" />
					<Label Style="{TemplateBinding LabelStyle}"
						Content="{TemplateBinding LabelContent}" />
					<Label Style="{TemplateBinding SecondLabelStyle}"
						Content="{TemplateBinding SecondLabelContent}"
						Visibility="{TemplateBinding SecondLabelVisability}"/>
				</StackPanel>
			</Grid>
		</ControlTemplate>

		<Style x:Key="InctiveServiceToggleRightBarStyle" TargetType="Rectangle">
			<Setter Property="Rectangle.Fill">
				<Setter.Value>
					<LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
						<GradientStop Color="#A3A3A3" Offset="0"></GradientStop>
						<GradientStop Color="#C0C0C0" Offset="1"></GradientStop>
					</LinearGradientBrush>
				</Setter.Value>
			</Setter>
		</Style>

		<Style x:Key="InctiveServiceToggleBottomBarStyle" TargetType="Canvas">
			<Setter Property="Background" Value="#828282" />
		</Style>

		<Style x:Key="InctiveServiceToggleCenterStyle" TargetType="Panel">
			<Setter Property="Background" Value="#34363D" />
		</Style>

		<ControlTemplate x:Key="InctiveServiceToggleTemplate"
						TargetType="appSettings:LabeledImageDataControl">
			<Grid
						Width="{Binding ServiceToggleWidth}"
						Height="{Binding ServiceToggleHeight}"
						Margin="0">

				<Grid.RowDefinitions>
					<RowDefinition Height="{StaticResource InctiveServiceToggleWithoutBottomBarHeight}" />
					<RowDefinition Height="{StaticResource InctiveServiceToggleBottomBarHeight}" />
				</Grid.RowDefinitions>

				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="{StaticResource InctiveServiceToggleWithoutRightBarWidth}" />
					<ColumnDefinition Width="{StaticResource InctiveServiceToggleRightBarWidth}" />
				</Grid.ColumnDefinitions>

				<Rectangle
					Grid.Row="0"
					Grid.Column="1"
					Style="{StaticResource InctiveServiceToggleRightBarStyle}" />

				<Canvas
					Grid.Row="1"
					Grid.Column="0"
					Style="{StaticResource InctiveServiceToggleBottomBarStyle}" />

				<StackPanel
						Grid.Row="0"
						Grid.Column="0"
						Style="{StaticResource InctiveServiceToggleCenterStyle}">
					<Image Style="{TemplateBinding ImageStyle}"
						Source="{TemplateBinding ImageSource}" />
					<Label Style="{TemplateBinding LabelStyle}"
						Content="{TemplateBinding LabelContent}"
						Foreground="{StaticResource InctiveServiceToggleLabelForegroundBrush}"/>
					<Label Style="{TemplateBinding SecondLabelStyle}"
						Content="{TemplateBinding SecondLabelContent}"
						Visibility="{TemplateBinding SecondLabelVisability}"
						Foreground="{StaticResource InctiveServiceToggleLabelForegroundBrush}"/>
				</StackPanel>
			</Grid>
		</ControlTemplate>

		<ControlTemplate x:Key="InctiveServiceToggleWithoutBottomBarTemplate"
				TargetType="appSettings:LabeledImageDataControl">
			<Grid
						Width="{Binding ServiceToggleWidth}"
						Height="{Binding ServiceToggleHeight}"
						Margin="0">

				<Grid.RowDefinitions>
					<RowDefinition Height="{StaticResource ServiceToggleHeight}" />
				</Grid.RowDefinitions>

				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="{StaticResource InctiveServiceToggleWithoutRightBarWidth}" />
					<ColumnDefinition Width="{StaticResource InctiveServiceToggleRightBarWidth}" />
				</Grid.ColumnDefinitions>

				<Rectangle
					Grid.Row="0"
					Grid.Column="1"
					Style="{StaticResource InctiveServiceToggleRightBarStyle}" />

				<StackPanel
						Grid.Row="0"
						Grid.Column="0"
						Style="{StaticResource InctiveServiceToggleCenterStyle}">
					<Image Style="{TemplateBinding ImageStyle}"
						Source="{TemplateBinding ImageSource}" />
					<Label Style="{TemplateBinding LabelStyle}"
						Content="{TemplateBinding LabelContent}"
						Foreground="{StaticResource InctiveServiceToggleLabelForegroundBrush}"/>
					<Label Style="{TemplateBinding SecondLabelStyle}"
						Content="{TemplateBinding SecondLabelContent}"
						Visibility="{TemplateBinding SecondLabelVisability}"
						Foreground="{StaticResource InctiveServiceToggleLabelForegroundBrush}"/>
				</StackPanel>
			</Grid>
		</ControlTemplate>

	</UserControl.Resources>

	<StackPanel
			Width="{Binding ServiceToggleWidth}"
			Height="{Binding ServiceToggleHeight}"
			Margin="0">

		<appSettings:LabeledImageDataControl
			x:Name="ActiveServiceToggle"
			ImageStyle="{StaticResource ServiceToggleImageStyle}"
			LabelStyle="{StaticResource ServiceToggleLabelStyle}"
			SecondLabelStyle="{StaticResource ServiceToggleSecondLabelStyle}"
			Template="{StaticResource ActiveServiceToggleTemplate}"/>
			<!--
			ImageSource="{TemplateBinding ActiveImageSource}"
			LabelContent="{TemplateBinding LabelContent}"
			LabelStyle="{TemplateBinding LabelStyle}" -> LabelIsTaight
			SecondLabelContent="{TemplateBinding SecondLabelContent}"
			SecondLabelStyle="{TemplateBinding SecondLabelStyle}" -> LabelIsTaight
			SecondLabelVisability -> SecondLabelContent
			-->

		<appSettings:LabeledImageDataControl
			x:Name="InactiveServiceToggle"
			ImageStyle="{StaticResource ServiceToggleImageStyle}"
			LabelStyle="{StaticResource ServiceToggleLabelStyle}"
			SecondLabelStyle="{StaticResource ServiceToggleSecondLabelStyle}"
			Template="{StaticResource InctiveServiceToggleTemplate}"/>
			<!--
			ImageSource="{TemplateBinding InactiveImageSource}"
			LabelContent="{TemplateBinding LabelContent}"
			LabelStyle="{TemplateBinding LabelStyle}" -> LabelIsTaight
			SecondLabelContent="{TemplateBinding SecondLabelContent}"
			SecondLabelStyle="{TemplateBinding SecondLabelStyle}" -> LabelIsTaight
			SecondLabelVisability -> SecondLabelContent
			Template="{StaticResource InctiveServiceToggleWithoutBottomBarTemplate}
				-> HasBottomBarWhileInctive
			-->

		<appSettings:SimpleToggle
			x:Name="ServiceToggle"
			AlwaysShowActiveImageIfIsAvailable="True"
			ActiveStateUIElement ="{Binding ElementName=ActiveServiceToggle}"
			InactiveStateUIElement ="{Binding ElementName=InactiveServiceToggle}"
			Checked="OnSimpleToggleChecked"/>
			<!--
			GroupIndex="{TemplateBinding GroupIndex}"
			IsChecked="{TemplateBinding IsChecked}"
			IsAvailable="{TemplateBinding IsAvailable}"
			AssociatedUIElement="{TemplateBinding AssociatedUIElement}"
			-->

	</StackPanel>

</UserControl>
