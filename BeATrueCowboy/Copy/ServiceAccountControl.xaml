<UserControl x:Class="Controls.ServiceAccountControl"
		xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
		xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
		xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
		xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
		xmlns:m="clr-namespace:Snack"
		xmlns:local="clr-namespace:Snack.Settings"
		xmlns:appSettings="clr-namespace:Controls"
		xmlns:sysWin="clr-namespace:System.Windows;assembly=PresentationFramework"
		xmlns:system="clr-namespace:System;assembly=mscorlib"
		xmlns:lang="clr-namespace:Snack.Language"
		mc:Ignorable="d"
		d:DesignHeight="41"
		d:DesignWidth="380"
		Height="41"
		Width="380"
		Foreground="Black"
		FontSize="12"
		FontFamily="/Snack;component/Resources/#Lucida Grande" >

	<UserControl.Resources>
		<system:Double x:Key="ControlDoubleHeight">41</system:Double>
		<system:Double x:Key="ControlDoubleWigth">380</system:Double>

		<sysWin:GridLength x:Key="ControlBarVerticalSideGridLengthWigth">3</sysWin:GridLength>
		<system:Double x:Key="ControlBarVerticalSideDoublehWigth">3</system:Double>
		<sysWin:GridLength x:Key="ControlBarCenterGridLengthWigth">374</sysWin:GridLength>
		<system:Double x:Key="ControlBarCenterDoubleWigth">374</system:Double>

		<Style x:Key="ControlBarVerticalSideStyle" TargetType="Canvas">
			<Setter Property="Height" Value="{StaticResource ControlDoubleHeight}" />
			<Setter Property="Width" Value="{StaticResource ControlBarVerticalSideDoublehWigth}" />
			<Setter Property="Margin" Value="0" />
		</Style>

		<sysWin:GridLength x:Key="IconAreaWithoutLeftBorderGridLengthWidth">38</sysWin:GridLength>
		<system:Double x:Key="IconDoubleSide">31</system:Double>
		<Style x:Key="IconBorderStyle" TargetType="Border">
			<Setter Property="Height" Value="{StaticResource IconDoubleSide}" />
			<Setter Property="Width" Value="{StaticResource IconDoubleSide}" />
			<Setter Property="Margin" Value="2,5,5,5" />
			<Setter Property="Padding" Value="0" />
			<Setter Property="CornerRadius" Value="5" />
		</Style>

		<sysWin:GridLength x:Key="AccountNameAndTeamAreaGridLengthWidth">296</sysWin:GridLength>
		<system:Double x:Key="AccountNameAndTeamAreaDoubleWidth">296</system:Double>

		<sysWin:GridLength x:Key="AccountNameGridLengthHeight">19.5</sysWin:GridLength>
		<sysWin:GridLength x:Key="AccountTeamGridLengthHeight">21.5</sysWin:GridLength>
		<sysWin:GridLength x:Key="AccountNameAndTeamCaptionsGridLengthWidth">60</sysWin:GridLength>
		<sysWin:GridLength x:Key="AccountNameAndTeamValuesGridLengthWidth">236</sysWin:GridLength>

		<Style x:Key="AccountNameLabelStyle" TargetType="Label">
			<Setter Property="HorizontalAlignment" Value="Left" />
			<Setter Property="VerticalAlignment" Value="Bottom" />
			<Setter Property="Margin" Value="0" />
			<Setter Property="Padding" Value="0" />
		</Style>
		<Style x:Key="AccountTeamLabelStyle" TargetType="Label">
			<Setter Property="HorizontalAlignment" Value="Left" />
			<Setter Property="VerticalAlignment" Value="Top" />
			<Setter Property="Margin" Value="0,-1.5,0,0" />
			<Setter Property="Padding" Value="0" />
		</Style>

		<sysWin:GridLength x:Key="MarkersAreaGridLengtheWidth">40</sysWin:GridLength>
		<system:Double x:Key="MarkersAreaDoubleWidth">40</system:Double>
		<system:Double x:Key="MarkerImageDoubleSide">12</system:Double>

		<Style x:Key="MarkerImageStyle" TargetType="Image">
			<Setter Property="Height" Value="{StaticResource MarkerImageDoubleSide}" />
			<Setter Property="Width" Value="{StaticResource MarkerImageDoubleSide}" />
			<Setter Property="Margin" Value="0,2,1,0" />
			<Setter Property="HorizontalAlignment" Value="Left" />
			<Setter Property="VerticalAlignment" Value="Top" />
		</Style>

	</UserControl.Resources>

	<Grid
			Height="{StaticResource ControlDoubleHeight}"
			Width="{StaticResource ControlDoubleWigth}">

		<Grid.RowDefinitions>
			<RowDefinition Height="Auto" />
		</Grid.RowDefinitions>

		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="{StaticResource ControlBarVerticalSideGridLengthWigth}"/>
			<ColumnDefinition Width="{StaticResource ControlBarCenterGridLengthWigth}"/>
			<ColumnDefinition Width="{StaticResource ControlBarVerticalSideGridLengthWigth}"/>
		</Grid.ColumnDefinitions>

		<Canvas
			Grid.Row="0"
			Grid.Column="0"
			Style="{StaticResource ControlBarVerticalSideStyle}" >
			<Canvas.Background>
				<ImageBrush ImageSource="/Snack;component/Resources/serviceAccountBar_left.png" />
			</Canvas.Background>
		</Canvas>

		<Canvas
			Grid.Row="0"
			Grid.Column="2"
			Style="{StaticResource ControlBarVerticalSideStyle}">
			<Canvas.Background>
				<ImageBrush ImageSource="/Snack;component/Resources/serviceAccountBar_right.png" />
			</Canvas.Background>
		</Canvas>

		<Grid
			Grid.Row="0"
			Grid.Column="1"
			Height="{StaticResource ControlDoubleHeight}"
			Width="{StaticResource ControlBarCenterDoubleWigth}"
			Margin="0" >
			<Grid.Background>
				<ImageBrush ImageSource="/Snack;component/Resources/serviceAccountBar_center.png" />
			</Grid.Background>

			<Grid.RowDefinitions>
				<RowDefinition Height="Auto" />
			</Grid.RowDefinitions>

			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="{StaticResource IconAreaWithoutLeftBorderGridLengthWidth}"/>
				<ColumnDefinition Width="{StaticResource AccountNameAndTeamAreaGridLengthWidth}"/>
				<ColumnDefinition Width="{StaticResource MarkersAreaGridLengtheWidth}"/>
			</Grid.ColumnDefinitions>

			<Border
				Grid.Row="0"
				Grid.Column="0"
				Style="{StaticResource IconBorderStyle}">
				<Border.Background>
					<ImageBrush x:Name="AccountImageBrushSource" />
					<!--ImageBrush x:Name="AccountImageBrushSource"
						ImageSource="{TemplateBinding AccountIconImageSource}"/-->
				</Border.Background>
			</Border>

			<Grid
					Grid.Row="0"
					Grid.Column="1"
					Height="{StaticResource ControlDoubleHeight}"
					Width="{StaticResource AccountNameAndTeamAreaDoubleWidth}"
					Margin="0" >

				<Grid.RowDefinitions>
					<RowDefinition Height="{StaticResource AccountNameGridLengthHeight}" />
					<RowDefinition Height="{StaticResource AccountTeamGridLengthHeight}" />
				</Grid.RowDefinitions>

				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="{StaticResource AccountNameAndTeamCaptionsGridLengthWidth}"/>
					<ColumnDefinition Width="{StaticResource AccountNameAndTeamValuesGridLengthWidth}"/>
				</Grid.ColumnDefinitions>

				<Label
					Grid.Column="0"
					Grid.Row="0"
					Content="{Binding Source={x:Static lang:LanguageManager.Instance}, Path=Settings_AccountNameTitle}"
					Style="{StaticResource AccountNameLabelStyle}" />

				<Label
					Grid.Column="0"
					Grid.Row="1"
					Content="{Binding Source={x:Static lang:LanguageManager.Instance}, Path=Settings_AccountTeamTitle}"
					Style="{StaticResource AccountTeamLabelStyle}" />

				<Label
					x:Name="AccountNameLabel"
					Grid.Column="1"
					Grid.Row="0"
					FontWeight="Bold"
					Style="{StaticResource AccountNameLabelStyle}" />
					<!--Content="{TemplateBinding AccountNameLabelContent}"-->

				<Label
					x:Name="AccountTeamLabel"
					Grid.Column="1"
					Grid.Row="1"
					Style="{StaticResource AccountTeamLabelStyle}" />
					<!--Content="{TemplateBinding AccountTeamLabelContent}"-->

			</Grid>

			<StackPanel
					Grid.Row="0"
					Grid.Column="2"
					Height="{StaticResource ControlDoubleHeight}"
					Width="{StaticResource MarkersAreaDoubleWidth}"
					Orientation="Horizontal"
					Margin="0" >

				<Image
					x:Name="ActiveFavoriteAccountToggle"
					Style="{StaticResource MarkerImageStyle}"
					Source="/Snack;component/Resources/activeFavoriteAccount.png" />

				<Image
					x:Name="InactiveFavoriteAccountToggle"
					Style="{StaticResource MarkerImageStyle}"
					Source="/Snack;component/Resources/inactiveFavoriteAccount.png" />

				<appSettings:SimpleToggle
					x:Name="FavoriteAccountToggle"
					IsAvailable="True"
					Checked="OnFavoriteAccountToggleChecked"
					ActiveStateUIElement ="{Binding ElementName=ActiveFavoriteAccountToggle}"
					InactiveStateUIElement ="{Binding ElementName=InactiveFavoriteAccountToggle}" />
					<!--
					GroupIndex="{TemplateBinding FavoriteAccountGroupIndex}"
					IsChecked="{TemplateBinding FavoriteAccountIsChecked}"
					-->

				<Image
					x:Name="ActiveAccountLocalSettingsToggle"
					Style="{StaticResource MarkerImageStyle}"
					Source="/Snack;component/Resources/activeAccountLocalSettings.png" />

				<Image
					x:Name="InactiveAccountLocalSettingsToggle"
					Style="{StaticResource MarkerImageStyle}"
					Source="/Snack;component/Resources/inactiveAccountLocalSettings.png" />

				<appSettings:SimpleToggle
					x:Name="AccountLocalSettingsToggle"
					IsAvailable="True"
					Checked="OnAccountLocalSettingsToggleChecked"
					ActiveStateUIElement ="{Binding ElementName=ActiveAccountLocalSettingsToggle}"
					InactiveStateUIElement ="{Binding ElementName=InactiveAccountLocalSettingsToggle}" />

				<Image
					x:Name="ActiveDeleteAccountToggle"
					Style="{StaticResource MarkerImageStyle}"
					Source="/Snack;component/Resources/activeDeleteAccount.png" />

				<Image
					x:Name="InactiveDeleteAccountToggle"
					Style="{StaticResource MarkerImageStyle}"
					Source="/Snack;component/Resources/inactiveDeleteAccount.png" />

				<appSettings:SimpleToggle
					x:Name="DeleteAccountToggle"
					IsAvailable="True"
					Checked="OnDeleteAccountToggleChecked"
					ActiveStateUIElement ="{Binding ElementName=ActiveDeleteAccountToggle}"
					InactiveStateUIElement ="{Binding ElementName=InactiveDeleteAccountToggle}" />

			</StackPanel>

		</Grid>

	</Grid>
</UserControl>
